Imports System
Imports System.Data
Imports System.Data.SqlClient
Imports Microsoft.SqlServer.Dts.Runtime

<Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute()>
<CLSCompliant(False)>
Partial Public Class ScriptMain
    Inherits Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase

    Enum ScriptResults
        Success = DTSExecResult.Success
        Failure = DTSExecResult.Failure
    End Enum

    Public Sub Main()

        Dim sqlConn As SqlConnection = Nothing
        Dim cm As ConnectionManager = Nothing

        Try

            Dim varProtokollSP As String = CStr(Dts.Variables("BA::ProtokollSP").Value)
            Dim varBAName As String = CStr(Dts.Variables("System::UserName").Value)
            Dim varTaskName As String = CStr(Dts.Variables("System::TaskName").Value)
            Dim varSourceName As String = CStr(Dts.Variables("System::SourceName").Value)
            Dim varErrorDescription As String = CStr(Dts.Variables("System::ErrorDescription").Value)
            Dim varPackageName As String = CStr(Dts.Variables("System::PackageName").Value)

            Dim varDatenbank As String = CStr(Dts.Variables("BA::Datenbank").Value)
            Dim varProtokollDatenbank As String = CStr(Dts.Variables("BA::ProtokollDB").Value)
            Dim varProtokolltabelle As String = CStr(Dts.Variables("BA::Protokolltabelle").Value)
            Dim varServer As String = CStr(Dts.Variables("BA::Server").Value)
            Dim varVerfahren As String = CStr(Dts.Variables("BA::Verfahren").Value)
            Dim varDatamart As String = CStr(Dts.Variables("BA::Datamart").Value)
            Dim varProtokollID As String = Guid.NewGuid().ToString()
            Dts.Variables("BA::ProtokollID").Value = varProtokollID


            varErrorDescription = varErrorDescription.Replace("'", "''")


            cm = Dts.Connections("Verbindung")
            Dim builder As New SqlConnectionStringBuilder(cm.ConnectionString)
            sqlConn = New SqlConnection(builder.ConnectionString)
            sqlConn.Open()

            Using cmd As New SqlCommand(varProtokollSP, sqlConn)
                cmd.CommandType = CommandType.StoredProcedure

                cmd.Parameters.Add("@Benutzer", SqlDbType.NVarChar).Value = varBAName
                cmd.Parameters.Add("@Datenbank", SqlDbType.NVarChar).Value = varDatenbank
                cmd.Parameters.Add("@Meldung", SqlDbType.NVarChar).Value = varErrorDescription
                cmd.Parameters.Add("@Meldungstyp", SqlDbType.NVarChar).Value = "info"
                cmd.Parameters.Add("@Paket", SqlDbType.NVarChar).Value = varPackageName
                cmd.Parameters.Add("@ProtokollDatenbank", SqlDbType.NVarChar).Value = varProtokollDatenbank
                cmd.Parameters.Add("@ProtokollID", SqlDbType.NVarChar).Value = varProtokollID
                cmd.Parameters.Add("@Protokolltabelle", SqlDbType.NVarChar).Value = varProtokolltabelle
                cmd.Parameters.Add("@Server", SqlDbType.NVarChar).Value = varServer
                cmd.Parameters.Add("@Task", SqlDbType.NVarChar).Value = varSourceName
                cmd.Parameters.Add("@Verfahren", SqlDbType.NVarChar).Value = varVerfahren
                cmd.Parameters.Add("@Datamart", SqlDbType.NVarChar).Value = varDatamart

                cmd.ExecuteNonQuery()
            End Using
            Dts.TaskResult = ScriptResults.Success

        Catch ex As Exception
            Dts.Events.FireError(0, "Script Task Fehler", ex.Message, "", 0)
            Dts.TaskResult = ScriptResults.Failure

        Finally
            If sqlConn IsNot Nothing AndAlso sqlConn.State <> ConnectionState.Closed Then
                sqlConn.Close()
            End If
        End Try

    End Sub

End Class
