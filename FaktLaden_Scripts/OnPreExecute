Imports System
Imports System.Data
Imports System.Data.SqlClient
Imports Microsoft.SqlServer.Dts.Runtime

' =============================================================================
'  Skript       : OnPreExecute (Paket-Eventhandler)
'  Paket        : Fakten Laden (SSIS)
'  Zweck        : Schreibt je startendem Task eine Zeile mit Startzeit in
'                 dbo.ETL_Fkt_TaskLaufzeit (Tabelle wird automatisch
'                 angelegt). OnPostExecute traegt spaeter die Endzeit nach.
'                 Auswertung: Gesamtlaufzeit = Zeile mit TaskName = Paketname,
'                 Task-Split = uebrige Zeilen je RunID.
'  Variablen    : ReadOnly: System::SourceName, System::SourceID,
'                 System::PackageName, BA::RunID
'  Protokoll    : Fehler im Handler werden verschluckt (Laufzeitmessung darf
'                 das Paket nie zum Absturz bringen)
' =============================================================================
<Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute()>
<CLSCompliant(False)>
Partial Public Class ScriptMain
    Inherits Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase

    Private ReadOnly ConnectionName As String = "Verbindung"

    Enum ScriptResults
        Success = DTSExecResult.Success
        Failure = DTSExecResult.Failure
    End Enum

    Public Sub Main()
        Dim sqlConn As SqlConnection = Nothing
        Try
            Dim sourceName As String = CStr(Dts.Variables("System::SourceName").Value)
            Dim sourceID As String = CStr(Dts.Variables("System::SourceID").Value)
            Dim packageName As String = CStr(Dts.Variables("System::PackageName").Value)

            Dim runID As Integer = 0
            Try
                runID = CInt(Dts.Variables("BA::RunID").Value)
            Catch
            End Try

            Dim cm As ConnectionManager = Dts.Connections(ConnectionName)
            Dim builder As New SqlConnectionStringBuilder(cm.ConnectionString)
            sqlConn = New SqlConnection(builder.ConnectionString)
            sqlConn.Open()

            Dim sql As String =
"IF NOT EXISTS (SELECT 1 FROM sys.tables WHERE name = 'ETL_Fkt_TaskLaufzeit' AND schema_id = SCHEMA_ID('dbo'))
BEGIN
    CREATE TABLE dbo.ETL_Fkt_TaskLaufzeit
    (
        ID            INT IDENTITY(1,1) NOT NULL
            CONSTRAINT PK_ETL_Fkt_TaskLaufzeit PRIMARY KEY,
        RunID         INT            NULL,
        PaketName     NVARCHAR(255)  NULL,
        TaskName      NVARCHAR(255)  NULL,
        SourceID      NVARCHAR(50)   NULL,
        Startzeit     DATETIME       NULL,
        Endzeit       DATETIME       NULL,
        DauerSekunden AS DATEDIFF(SECOND, Startzeit, Endzeit)
    );
END;

INSERT INTO dbo.ETL_Fkt_TaskLaufzeit (RunID, PaketName, TaskName, SourceID, Startzeit)
VALUES (@RunID, @Paket, @Task, @SourceID, GETDATE());"

            Using cmd As New SqlCommand(sql, sqlConn)
                cmd.CommandTimeout = 30
                cmd.Parameters.Add("@RunID", SqlDbType.Int).Value = runID
                cmd.Parameters.Add("@Paket", SqlDbType.NVarChar, 255).Value = packageName
                cmd.Parameters.Add("@Task", SqlDbType.NVarChar, 255).Value = sourceName
                cmd.Parameters.Add("@SourceID", SqlDbType.NVarChar, 50).Value = sourceID
                cmd.ExecuteNonQuery()
            End Using

            Dts.TaskResult = ScriptResults.Success

        Catch ex As Exception
            ' Laufzeitmessung darf das Paket nie stoppen - Fehler nur als Info melden
            Dim fireAgain As Boolean = False
            Dts.Events.FireInformation(0, "OnPreExecute",
                "WARNUNG Laufzeitmessung (Start): " & ex.Message, "", 0, fireAgain)
            Dts.TaskResult = ScriptResults.Success
        Finally
            If sqlConn IsNot Nothing AndAlso sqlConn.State <> ConnectionState.Closed Then
                sqlConn.Close()
            End If
        End Try
    End Sub

End Class
