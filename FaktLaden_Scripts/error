Package	SCR08_Template_Erstellen	info	SQL Statement [Template erstellen/pruefen]: DECLARE @t  nvarchar(128) = N'tf_bst_aufenthalt';
DECLARE @s  nvarchar(128) = N'xro_dm_stat_bst';
DECLARE @db nvarchar(128) = N'msi_dm_bst_v3';
DECLARE @cols nvarchar(max), @sql nvarchar(max), @tmpl nvarchar(300), @tmplObj int, @d int;

-- Soll-Spalten (columns_dbo) aus tm_polybase_struktur laden
SELECT @cols = STRING_AGG(CAST(columns_dbo AS nvarchar(max)), CONCAT(N',', CHAR(13), CHAR(10)))
                 WITHIN GROUP (ORDER BY colno)
FROM dbo.tm_polybase_struktur
WHERE tabname = LOWER(@t) AND themengebiet = @s;

IF @cols IS NULL
    THROW 50001, 'Keine columns_dbo Metadaten gefunden', 1;

SET @tmpl    = CONCAT('[', @db, '].dbo.[', @t, '_template]');
SET @tmplObj = OBJECT_ID(@tmpl);

IF @tmplObj IS NULL
BEGIN
    -- Template existiert nicht -> aus columns_dbo erstellen (nur Struktur)
    SET @sql = N'SELECT TOP 0 ' + @cols + N' INTO ' + @tmpl + N' FROM ext.[' + @t + N'];';
    EXEC sp_executesql @sql;
END
ELSE
BEGIN
    -- Template existiert -> Struktur (Spaltenname/Typ/Laenge/Nullable) gegen Soll pruefen
    SET @sql =
        N'SELECT TOP 0 ' + @cols + N' INTO #soll FROM ext.[' + @t + N'];' +
        N';WITH soll AS (SELECT c.name COLLATE DATABASE_DEFAULT AS nm, ty.name COLLATE DATABASE_DEFAULT AS typ, c.max_length AS ml, c.precision AS pr, c.scale AS sc, c.is_nullable AS nu' +
          N' FROM tempdb.sys.columns c JOIN tempdb.sys.types ty ON ty.user_type_id=c.user_type_id WHERE c.object_id=OBJECT_ID(N''tempdb..#soll'')),' +
          N' ist AS (SELECT c.name COLLATE DATABASE_DEFAULT AS nm, ty.name COLLATE DATABASE_DEFAULT AS typ, c.max_length AS ml, c.precision AS pr, c.scale AS sc, c.is_nullable AS nu' +
          N' FROM ' + QUOTENAME(@db) + N'.sys.columns c JOIN ' + QUOTENAME(@db) + N'.sys.types ty ON ty.user_type_id=c.user_type_id WHERE c.object_id=@po)' +
          N' SELECT @cnt = COUNT(*) FROM ((SELECT * FROM soll EXCEPT SELECT * FROM ist) UNION ALL (SELECT * FROM ist EXCEPT SELECT * FROM soll)) x;';
    EXEC sp_executesql @sql, N'@po int, @cnt int OUTPUT', @po=@tmplObj, @cnt=@d OUTPUT;
    IF @d > 0
        THROW 50010, 'Template-Struktur weicht von columns_dbo (Soll) ab', 1;
END
